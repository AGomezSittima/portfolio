---
import { Image } from "astro:assets";

interface Props {
  projectId: number;
  alt: string;
  class?: string;
  isDarkMode?: boolean;
}

const { projectId, alt, class: className, isDarkMode } = Astro.props;

const projectImagesFolder = "/src/assets/projects";
const projectImagesPath = `${projectImagesFolder}/*.webp`;
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*.webp"
);

const imagePath = `${projectImagesFolder}/Thumbnail_${projectId}${isDarkMode ? "_Dark" : ""}.webp`;

if (!images[imagePath]) {
  throw new Error(
    `"${imagePath}" does not exist in glob: "${projectImagesPath}"`
  );
}
---

<Image
  src={images[imagePath]()}
  alt={alt}
  class:list={["size-full object-cover", className]}
/>
