---
import type { AcceptedLanguage } from "@/i18n";
import type { WorkProjectDTO } from "@/i18n/data/projects";
import { formatDate } from "@/lib/dates";

import { LucideChevronRight } from "lucide-react";
import TechList from "./tech-list.astro";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "./ui/card";

interface Props {
  project: WorkProjectDTO;
  language: AcceptedLanguage;
}

const { project, language } = Astro.props;
---

<div class="group relative">
  <span
    class="bg-primary absolute top-3 -left-7.5 hidden size-3 animate-ping rounded-full group-hover:inline-block"
  ></span>
  <span class="bg-primary absolute top-3 -left-7.5 size-3 rounded-full"></span>

  <Card
    className="bg-card/50 group-hover:border-primary/40 px-4 py-6 backdrop-blur-sm transition group-hover:-translate-y-0.5"
  >
    <CardHeader>
      <CardTitle>
        <h3 class="text-2xl font-semibold">{project["company"]}</h3>
      </CardTitle>
      <CardDescription>
        <p class="text-muted-foreground mb-2 text-sm">
          <strong class="text-primary font-medium">
            {project["role"][language]}
          </strong>
          &bull;
          {formatDate(project["startDate"], language)}
          -
          {formatDate(project["endDate"], language)}
        </p>
      </CardDescription>
      <CardAction>
        <TechList
          projectId={project.id}
          technologies={project.technologies}
          maxTechBadgesDisplayed={2}
        />
      </CardAction>
    </CardHeader>
    <CardContent className="px-8">
      <div class="text-muted-foreground">
        <ul class="space-y-4">
          {
            project["responsibilities"][language].map((responsibility) => (
              <li class="flex items-start gap-4">
                <span>
                  <LucideChevronRight className="size-3.5 inline-block" />
                </span>
                <span>{responsibility}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </CardContent>
  </Card>
</div>
